# This file is for reference only. Mirage does not read .env files.
# Configuration is done via config.toml (see README.md).
#
# XDG config path: ~/.config/Mirage/config.toml
# CLI override:    mirage -c /path/to/config.toml

# RUST_LOG controls log verbosity in non-TUI mode (error|warn|info|debug|trace)
RUST_LOG=info

# MIRAGE_NO_UI=1 disables the live dashboard even on an interactive terminal
# MIRAGE_NO_UI=1
